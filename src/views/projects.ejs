<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>
        <p>Here are a few of our upcoming service projects:</p>
        
        <ul class="projects-list">
            <% projects.forEach(project => { %>
                <li style="margin-bottom: 20px; list-style: none; border-bottom: 1px solid #ccc; padding-bottom: 15px;">
                    <h2><%= project.title %></h2>
                    <p><strong>Sponsored by:</strong> <%= project.sponsor_organization %></p>
                    <p><%= project.description %></p>
                    <p>📍 <strong>Location:</strong> <%= project.location %></p>
                    <p>📅 <strong>Date:</strong> <%= new Date(project.project_date).toLocaleDateString() %></p>
                </li>
            <% }); %>
        </ul>
    </main>

<%- include('partials/footer') %>